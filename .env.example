# Development environment variables
NODE_ENV=development
LOG_LEVEL=debug

# Server configuration
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/job_service

# JWT & Auth
JWT_ENABLED=true

# Internal service token
INTERNAL_TOKEN=your-internal-secret-token-here

# MinIO (artifact storage) – required when submitting code/project for jobs
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=job-artifacts

# Redis (log streaming pub/sub)
REDIS_URL=redis://localhost:6379
