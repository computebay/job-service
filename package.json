{
  "name": "job-service",
  "description": "Job Service for ComputeBay distributed compute platform",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "format": "prettier --write .",
    "lint": "bunx eslint . --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@prisma/client": "^6.9.0",
    "amqplib": "^0.10.9",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bun": "latest",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.1.1",
    "prisma": "^6.9.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}